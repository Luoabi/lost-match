<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索拾获物品..." bindinput="onSearchInput" value="{{searchKeyword}}" />
    <button class="filter-btn" bindtap="showFilter">筛选</button>
  </view>

  <view class="filter-tags" wx:if="{{filterType || filterStatus}}">
    <view class="tag" wx:if="{{filterType}}" bindtap="clearTypeFilter">
      {{filterType}} <text class="close">×</text>
    </view>
    <view class="tag" wx:if="{{filterStatus}}">
      {{filterStatusText}} <text class="close" bindtap="clearStatusFilter">×</text>
    </view>
  </view>

  <view class="list">
    <view class="item" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="item-image">
        <image src="{{item.images[0] || '/images/default.png'}}" mode="aspectFill" />
        <view class="status-badge status-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="item-content">
        <view class="item-title">{{item.title}}</view>
        <view class="item-info">
          <text class="type">{{item.type}}</text>
          <text class="location">{{item.location}}</text>
        </view>
        <view class="item-desc">{{item.description}}</view>
        <view class="item-footer">
          <text class="time">{{item.foundTime}}</text>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{!loading && list.length === 0}}">
      <image src="/images/empty.png" class="empty-image" />
      <text class="empty-text">暂无拾获信息</text>
    </view>

    <view class="load-more" wx:if="{{hasMore}}">加载更多...</view>
    <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>
  </view>

  <view class="filter-modal" wx:if="{{showFilterModal}}" bindtap="hideFilter">
    <view class="filter-content" catchtap="stopPropagation">
      <view class="filter-title">筛选条件</view>
      
      <view class="filter-section">
        <view class="section-title">物品类型</view>
        <view class="filter-options">
          <view class="option {{filterType === item ? 'active' : ''}}" 
                wx:for="{{typeOptions}}" wx:key="index" wx:for-item="item"
                bindtap="selectType" data-type="{{item}}">
            {{item}}
          </view>
        </view>
      </view>

      <view class="filter-section">
        <view class="section-title">状态</view>
        <view class="filter-options">
          <view class="option {{filterStatus === item.value ? 'active' : ''}}" 
                wx:for="{{statusOptions}}" wx:key="value"
                bindtap="selectStatus" data-status="{{item.value}}">
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="filter-actions">
        <button class="reset-btn" bindtap="resetFilter">重置</button>
        <button class="confirm-btn" bindtap="confirmFilter">确定</button>
      </view>
    </view>
  </view>

  <view class="fab" bindtap="goPublish">
    <text class="fab-icon">+</text>
  </view>
</view>
