.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 20rpx;
}

.score-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx;
  text-align: center;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.score-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.total-score {
  font-size: 100rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  position: relative;
  z-index: 1;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.score-label {
  font-size: 30rpx;
  opacity: 0.95;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 1;
  font-weight: 500;
}

.score-details {
  display: flex;
  justify-content: space-around;
  position: relative;
  z-index: 1;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  backdrop-filter: blur(10rpx);
  min-width: 180rpx;
}

.score-name {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.score-value {
  font-size: 40rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.status-card {
  background: #fff;
  margin: 20rpx;
  padding: 35rpx;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
}

.status-badge {
  display: inline-block;
  padding: 18rpx 50rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.status-0 { background: linear-gradient(135deg, #FFA726 0%, #FB8C00 100%); }
.status-1 { background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%); }
.status-2 { background: linear-gradient(135deg, #BDBDBD 0%, #9E9E9E 100%); }

.item-card {
  background: #fff;
  margin: 20rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
  position: relative;
  overflow: hidden;
}

.item-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 35rpx;
  padding-bottom: 20rpx;
  border-bottom: 3rpx solid #E9ECEF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title text:first-child {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.view-detail {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
  display: flex;
  align-items: center;
}

.item-images {
  display: flex;
  gap: 18rpx;
  margin-bottom: 25rpx;
  overflow-x: auto;
  padding-bottom: 10rpx;
}

.item-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
}

.item-image:active {
  transform: scale(0.95);
}

.item-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 18rpx;
  font-weight: 600;
}

.item-info {
  display: flex;
  gap: 18rpx;
  margin-bottom: 18rpx;
  flex-wrap: wrap;
}

.info-tag {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #F8F9FA 0%, #E9ECEF 100%);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #606266;
  font-weight: 500;
  border: 2rpx solid #E9ECEF;
}

.item-desc {
  font-size: 28rpx;
  color: #606266;
  line-height: 1.8;
  margin-bottom: 18rpx;
  padding: 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.item-time {
  font-size: 24rpx;
  color: #909399;
  display: flex;
  align-items: center;
}

.item-time::before {
  content: '🕐';
  margin-right: 6rpx;
}

.feedback-card {
  background: #fff;
  margin: 20rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
}

.feedback-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 24rpx;
  background: #F8F9FA;
  border: 2rpx solid #E9ECEF;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 25rpx;
  box-sizing: border-box;
  line-height: 1.6;
  transition: all 0.3s ease;
}

.feedback-textarea:focus {
  background: #fff;
  border-color: #667eea;
}

.submit-feedback-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 45rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
  border: none;
}

.submit-feedback-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
}

.actions {
  padding: 20rpx;
  display: flex;
  gap: 25rpx;
}

.action-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  border: none;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: translateY(2rpx);
}

.confirm-btn {
  background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%);
  color: #fff;
}

.confirm-btn::before {
  content: '✓ ';
}

.reject-btn {
  background: #fff;
  color: #F56C6C;
  border: 3rpx solid #F56C6C;
}

.reject-btn::before {
  content: '✗ ';
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.loading::before {
  content: '⏳';
  margin-right: 10rpx;
  font-size: 40rpx;
}
