.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 20rpx;
}

/* 我的模式提示 */
.mine-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #667eea;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tip-left {
  display: flex;
  align-items: center;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 28rpx;
  font-weight: 600;
}

.tip-right {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 25rpx;
  transition: all 0.3s;
}

.tip-right:active {
  transform: scale(0.95);
}

.exit-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.filter-bar {
  padding: 20rpx;
  background: transparent;
  margin-bottom: 20rpx;
}

.filter-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #667eea;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  border: none;
}

.filter-btn::before {
  content: '🔍 ';
}

.list {
  padding: 0 20rpx;
}

.match-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 35rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.match-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.match-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 35rpx;
}

.match-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
}

.score-value {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
  font-weight: 500;
}

.status-badge {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.status-0 { background: linear-gradient(135deg, #FFA726 0%, #FB8C00 100%); }
.status-1 { background: linear-gradient(135deg, #66BB6A 0%, #43A047 100%); }
.status-2 { background: linear-gradient(135deg, #BDBDBD 0%, #9E9E9E 100%); }

.match-items {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 35rpx;
  padding: 25rpx;
  background: linear-gradient(135deg, #F8F9FA 0%, #E9ECEF 100%);
  border-radius: 16rpx;
}

.item-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.item-label {
  font-size: 24rpx;
  color: #667eea;
  margin-bottom: 18rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
}

.item-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.item-title {
  font-size: 28rpx;
  color: #333;
  text-align: center;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  font-weight: 500;
}

.item-location {
  font-size: 24rpx;
  color: #909399;
  display: flex;
  align-items: center;
}

.item-location::before {
  content: '📍';
  margin-right: 4rpx;
}

.match-icon {
  font-size: 64rpx;
  color: #667eea;
  margin: 0 25rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

.match-scores {
  display: flex;
  justify-content: space-around;
  padding: 25rpx 0;
  border-top: 2rpx solid #E9ECEF;
  border-bottom: 2rpx solid #E9ECEF;
  margin-bottom: 25rpx;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-name {
  font-size: 24rpx;
  color: #909399;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.score-num {
  font-size: 36rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.match-time {
  font-size: 24rpx;
  color: #909399;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.match-time::before {
  content: '🕐';
  margin-right: 6rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  margin: 20rpx;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 30rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 30rpx;
  color: #606266;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: #909399;
  text-align: center;
  line-height: 1.6;
}

.load-more,
.no-more {
  text-align: center;
  padding: 35rpx 0;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.filter-content {
  width: 100%;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 50rpx 40rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.filter-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.filter-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 50rpx;
}

.option {
  padding: 28rpx;
  background: #F8F9FA;
  border: 2rpx solid #E9ECEF;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #606266;
  text-align: center;
  transition: all 0.3s ease;
  font-weight: 500;
}

.option.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
  transform: scale(1.02);
}

.filter-actions {
  display: flex;
  gap: 20rpx;
}

.reset-btn,
.confirm-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.reset-btn {
  background: #F5F5F5;
  color: #606266;
}

.confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
}
