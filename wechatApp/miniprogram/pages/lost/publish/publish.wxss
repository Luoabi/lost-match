.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

.form-section {
  background: #fff;
  margin: 20rpx;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 35rpx;
  padding-bottom: 20rpx;
  border-bottom: 3rpx solid transparent;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 2rpx;
}

.form-item {
  margin-bottom: 35rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 18rpx;
  display: block;
  font-weight: 500;
}

.label.required::before {
  content: '*';
  color: #FF6B6B;
  margin-right: 5rpx;
  font-weight: bold;
}

.input,
.picker {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  background: #F8F9FA;
  border: 2rpx solid #E9ECEF;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.3s ease;
}

.input:focus {
  background: #fff;
  border-color: #667eea;
}

.picker {
  color: #909399;
  display: flex;
  align-items: center;
}

.textarea {
  min-height: 220rpx;
  padding: 24rpx;
  background: #F8F9FA;
  border: 2rpx solid #E9ECEF;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  transition: all 0.3s ease;
}

.textarea:focus {
  background: #fff;
  border-color: #667eea;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
}

.image-item:active {
  transform: scale(0.95);
}

.image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF5252 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  line-height: 1;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.4);
  transition: all 0.3s ease;
}

.delete-btn:active {
  transform: scale(0.9);
}

.add-btn {
  background: linear-gradient(135deg, #F8F9FA 0%, #E9ECEF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed #CED4DA;
  transition: all 0.3s ease;
}

.add-btn:active {
  background: linear-gradient(135deg, #E9ECEF 0%, #DEE2E6 100%);
  border-color: #667eea;
}

.add-icon {
  font-size: 64rpx;
  color: #667eea;
  line-height: 1;
  margin-bottom: 12rpx;
  font-weight: 300;
}

.add-text {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
}

.tip {
  font-size: 24rpx;
  color: #909399;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
}

.tip::before {
  content: 'ℹ️';
  margin-right: 8rpx;
}

.location-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  font-weight: 500;
}

.location-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.3);
}

.location-btn::before {
  content: '📍 ';
}

.submit-section {
  padding: 0 20rpx;
  margin-top: 50rpx;
  margin-bottom: 20rpx;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
  border: none;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.submit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s ease;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 8rpx 25rpx rgba(102, 126, 234, 0.4);
}

.submit-btn:active::before {
  left: 100%;
}

.placeholder {
  color: #ADB5BD;
  font-size: 26rpx;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.form-section {
  animation: fadeIn 0.5s ease;
}

.form-section:nth-child(1) {
  animation-delay: 0.1s;
}

.form-section:nth-child(2) {
  animation-delay: 0.2s;
}

.form-section:nth-child(3) {
  animation-delay: 0.3s;
}

.form-section:nth-child(4) {
  animation-delay: 0.4s;
}
