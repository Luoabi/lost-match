/* 首页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F7FA 0%, #FFFFFF 100%);
  padding-bottom: 20rpx;
}

/* 下拉刷新滚动容器 */
.scroll-container {
  height: 100vh;
}

/* 顶部横幅 - 增加高度和内容 */
.header-banner {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 50rpx 30rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}

.header-banner::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.banner-content {
  flex: 1;
  z-index: 1;
}

.banner-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.banner-subtitle {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.subtitle-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.banner-features {
  display: flex;
  gap: 20rpx;
  margin-top: 15rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.feature-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.feature-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.95);
}

.banner-decoration {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.decoration-icon {
  font-size: 80rpx;
  opacity: 0.3;
  animation: rotate 10s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.decoration-circle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  animation: scale-pulse 3s ease-in-out infinite;
}

@keyframes scale-pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.3; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.1; }
}

/* 统计卡片区域 - 调整位置 */
.stats-section {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
  padding: 0 20rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.stat-card:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.stat-info {
  text-align: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #909399;
  display: block;
}

/* 快捷操作区域 - 缩小尺寸 */
.quick-section {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

.action-btn {
  border-radius: 12rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-btn.success {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.action-btn .action-icon {
  font-size: 50rpx;
  margin-bottom: 10rpx;
  z-index: 1;
}

.action-btn .action-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  z-index: 1;
}

/* 列表区域 - 优化间距 */
.list-section {
  background: #fff;
  margin: 0 20rpx 15rpx;
  border-radius: 12rpx;
  padding: 25rpx 25rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.title-text {
  font-size: 30rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #667eea;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(102, 126, 234, 0.08);
  transition: all 0.3s;
}

.section-more:active {
  background: rgba(102, 126, 234, 0.15);
}

.arrow {
  font-size: 32rpx;
  margin-left: 2rpx;
}

/* 横向滚动列表 */
.scroll-list {
  white-space: nowrap;
  display: flex;
  margin: 0 -25rpx;
  padding: 0 25rpx;
}

.scroll-item {
  display: inline-block;
  width: 280rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 15rpx;
  vertical-align: top;
  transition: all 0.3s;
}

.scroll-item:last-child {
  margin-right: 0;
}

.scroll-item:active {
  transform: scale(0.95);
  background: #E8EBF0;
}

.scroll-image {
  width: 280rpx;
  height: 180rpx;
  display: block;
  background: #E8EBF0;
}

.scroll-content {
  padding: 15rpx;
}

.scroll-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scroll-tags {
  margin-bottom: 8rpx;
}

.scroll-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  background: #E8F4FF;
  color: #4A90E2;
}

.scroll-location {
  font-size: 22rpx;
  color: #FF9800;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scroll-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.scroll-time {
  font-size: 22rpx;
  color: #909399;
}

.scroll-reward {
  font-size: 24rpx;
  color: #F56C6C;
  font-weight: bold;
}

/* 空状态 - 缩小尺寸 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 15rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 26rpx;
  color: #909399;
}
