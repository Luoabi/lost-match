<view class="container">
  <!-- 用户信息头部 -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="user-card">
      <view class="user-info">
        <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="user-details">
          <view class="username">{{userInfo.realName || userInfo.username || '未设置'}}</view>
          <view class="user-meta">
            <text class="meta-item">{{userInfo.role === 'admin' ? '👑 管理员' : userInfo.role === 'teacher' ? '👨‍🏫 教师' : '🎓 学生'}}</text>
          </view>
          <view class="user-contact" wx:if="{{userInfo.phone}}">
            <text>📱 {{userInfo.phone}}</text>
          </view>
        </view>
        <view class="edit-btn" bindtap="showEdit">
          <text class="edit-icon">✏️</text>
        </view>
      </view>

      <!-- 统计数据卡片 -->
      <view class="stats-grid">
        <view class="stat-box" bindtap="goMyLost">
          <view class="stat-number">{{stats.lostCount}}</view>
          <view class="stat-text">我的失物</view>
        </view>
        <view class="stat-box" bindtap="goMyFound">
          <view class="stat-number">{{stats.foundCount}}</view>
          <view class="stat-text">我的拾获</view>
        </view>
        <view class="stat-box" bindtap="goMyMatch">
          <view class="stat-number">{{stats.matchCount}}</view>
          <view class="stat-text">匹配记录</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-list">
      <view class="menu-item" bindtap="goMyLost">
        <view class="menu-left">
          <view class="menu-icon">📋</view>
          <view class="menu-info">
            <view class="menu-title">我的失物</view>
            <view class="menu-desc">查看我发布的失物信息</view>
          </view>
        </view>
        <view class="menu-right">
          <text class="menu-badge" wx:if="{{stats.lostCount > 0}}">{{stats.lostCount}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="menu-item" bindtap="goMyFound">
        <view class="menu-left">
          <view class="menu-icon">🎁</view>
          <view class="menu-info">
            <view class="menu-title">我的拾获</view>
            <view class="menu-desc">查看我发布的拾获物品</view>
          </view>
        </view>
        <view class="menu-right">
          <text class="menu-badge" wx:if="{{stats.foundCount > 0}}">{{stats.foundCount}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="menu-item" bindtap="goMyMatch">
        <view class="menu-left">
          <view class="menu-icon">🔗</view>
          <view class="menu-info">
            <view class="menu-title">匹配记录</view>
            <view class="menu-desc">查看AI智能匹配结果</view>
          </view>
        </view>
        <view class="menu-right">
          <text class="menu-badge" wx:if="{{stats.matchCount > 0}}">{{stats.matchCount}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 个人信息 -->
  <view class="info-section">
    <view class="info-card">
      <view class="info-item" bindtap="showEdit">
        <view class="info-left">
          <view class="info-icon">👤</view>
          <text class="info-label">个人信息</text>
        </view>
        <view class="info-right">
          <text class="info-value">{{userInfo.realName || '未完善'}}</text>
          <text class="info-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">
      <text class="logout-icon">🚪</text>
      <text>退出登录</text>
    </button>
  </view>

  <!-- 编辑弹窗 -->
  <view class="edit-modal" wx:if="{{showEditModal}}" bindtap="hideEdit">
    <view class="edit-content" catchtap="stopPropagation">
      <view class="edit-header">
        <view class="edit-title">编辑个人信息</view>
        <view class="edit-close" bindtap="hideEdit">✕</view>
      </view>
      
      <view class="edit-body">
        <view class="edit-item">
          <view class="edit-label">
            <text class="label-icon">👤</text>
            <text>真实姓名</text>
          </view>
          <input class="edit-input" placeholder="请输入真实姓名" value="{{editForm.realName}}" bindinput="onEditInput" data-field="realName" />
        </view>

        <view class="edit-item">
          <view class="edit-label">
            <text class="label-icon">📱</text>
            <text>手机号码</text>
          </view>
          <input class="edit-input" type="number" placeholder="请输入手机号" value="{{editForm.phone}}" bindinput="onEditInput" data-field="phone" maxlength="11" />
        </view>

        <view class="edit-item">
          <view class="edit-label">
            <text class="label-icon">📧</text>
            <text>电子邮箱</text>
          </view>
          <input class="edit-input" placeholder="请输入邮箱（选填）" value="{{editForm.email}}" bindinput="onEditInput" data-field="email" />
        </view>

        <view class="edit-item">
          <view class="edit-label">
            <text class="label-icon">🎓</text>
            <text>学号</text>
          </view>
          <input class="edit-input" placeholder="请输入学号（选填）" value="{{editForm.studentId}}" bindinput="onEditInput" data-field="studentId" />
        </view>

        <view class="edit-item">
          <view class="edit-label">
            <text class="label-icon">🏫</text>
            <text>院系</text>
          </view>
          <input class="edit-input" placeholder="请输入院系（选填）" value="{{editForm.department}}" bindinput="onEditInput" data-field="department" />
        </view>
      </view>

      <view class="edit-actions">
        <button class="cancel-btn" bindtap="hideEdit">取消</button>
        <button class="save-btn" bindtap="saveEdit">保存</button>
      </view>
    </view>
  </view>
</view>
